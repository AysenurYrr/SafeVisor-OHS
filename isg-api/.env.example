# Environment (development, staging, production)
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://isg_user:isg_password@localhost/isg_db

# JWT Security - IMPORTANT: Change these in production!
SECRET_KEY=your-super-secret-jwt-key-change-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
# For development, use localhost origins
# For production, replace with your actual frontend domain(s)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]

# Security Settings
# Set to true in production when using HTTPS
USE_HTTPS=false
COOKIE_SECURE=false  # Must be true in production with HTTPS
COOKIE_SAMESITE=lax  # Options: lax, strict, none
COOKIE_DOMAIN=  # Leave empty for development, set to your domain in production (e.g., .yourdomain.com)

# Rate Limiting
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT=5/minute  # Limit login attempts per IP

# File Upload Limits
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_UPLOAD_EXTENSIONS=[".jpg",".jpeg",".png",".gif",".bmp"]

# Admin User (for initial setup only)
FIRST_SUPERUSER_EMAIL=admin@isg.com
FIRST_SUPERUSER_PASSWORD=admin123  # CHANGE THIS IN PRODUCTION!
